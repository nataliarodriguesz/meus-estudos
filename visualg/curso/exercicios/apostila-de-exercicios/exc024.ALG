algoritmo "ExercÌcio 24"
var
   P, D: Real
inicio
      Escreval ("--------------------")
      Escreval ("PRE«O DA PASSAGEM")
      Escreval ("--------------------")
      Escreval ("Qual a dist‚ncia que deseja percorrer? Em Km")
      Leia (D)
      P <- 0
           Se (D < 200) entao
              P <- D * 50/100
           Senao
              P <- D * 45/100
           FimSe
       Escreval ("O preÁo da passagem ser· de R$", P:4:2)
fimalgoritmo