algoritmo "Exercício20"
var
   N: Inteiro
inicio
      Escreval ("----------------")
      Escreval ("PAR OU ÍMPAR")
      Escreval ("----------------")
      Escreva ("Digite um número: ")
      Leia (N)
           Se (N % 2 = 0) entao
              Escreval ("O número é PAR")
           Senao
              Escreval ("O número é ÍMPAR")
           FimSe
fimalgoritmo