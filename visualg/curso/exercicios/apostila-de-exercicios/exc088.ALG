algoritmo "Exercício88"
var
Procedimento Gerador(M:caractere; N:Inteiro)
var
C: Inteiro
Inicio
   Escreval ("+---------------------+")
   Para C <- 1 ate N faca
      Escreval ("  ", M)
   FimPara
   Escreval ("+---------------------+")
FimProcedimento
inicio
   Gerador ("Aprendendo Portugal", 4)
fimalgoritmo