algoritmo "Exercício05"
var
   Nome: Caractere
   N1, N2, M: Real
inicio
      Escreva ("Nome: ")
      Leia (Nome)
      Escreva ("Nota 1: ")
      Leia (N1)
      Escreva ("Nota 2: ")
      Leia (N2)
      M <- (N1 + N2)/2
      Escreval ("A média entre ", N1, " e ", N2, " é igual a ",M)
fimalgoritmo