algoritmo "Exercício21"
var
   Ano: Inteiro
inicio
      Escreval ("--------------------")
      Escreval ("ANO BISSEXTO")
      Escreval ("--------------------")
      Escreva ("Digite o ano: ")
      Leia (Ano)
           Se (Ano % 4 = 0) entao
              Escreval ("O ano É BISSEXTO")
           Senao
              Escreval ("O ano NĂO É BISSEXTO")
           FimSe
fimalgoritmo