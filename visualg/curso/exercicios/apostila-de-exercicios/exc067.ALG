algoritmo "Exercício67"
var
   C, V: Inteiro
inicio
   Escreval ("----------------------------")
   Escreval ("          CONTAGEM          ")
   Escreval ("----------------------------")
   Escreva ("Digite um valor: ")
   Leia (V)
   Escreval ("----------------------------")
   Escreva ("Contagem: ")
   Para C <- 0 ate V faca
      Escreva (C, "  ")
   FimPara
   Escreva ("Acabou!")
fimalgoritmo