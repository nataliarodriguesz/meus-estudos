algoritmo "Exercício 10"
var
   h, l, A, T: Real
inicio
      Escreva ("Altura da parede: ")
      Leia (h)
      Escreva ("Largura da parede: ")
      Leia (l)
      A <- l * h
      T <- A/2
      Escreval ("Área a ser pintada: ", A:4:2, "m²")
      Escreval ("Quantidade de tinta necessária: ", T:4:2, " litros")
fimalgoritmo