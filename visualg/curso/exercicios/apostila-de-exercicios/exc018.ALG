algoritmo "Exercício18"
var
   Nasc, Atual, ID: Inteiro
inicio
      Escreval ("-------------------")
      Escreval ("IDADE X VOTO")
      Escreval ("-------------------")
      Escreva ("Ano de Nascimento: ")
      Leia (Nasc)
      Escreva ("Ano Atual: ")
      Leia (Atual)
      ID <- Atual - Nasc
           Se (ID >= 18) entao
              Escreva ("Vocę está APTO a votar")
           Senao
              Escreva ("Vocę NĂO está APTO a votar")
           FimSe
fimalgoritmo