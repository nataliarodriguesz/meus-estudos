Algoritmo "EX12 L01"

// Exercício 12:
//    Leia 3 números inteiros e calcule a multiplicaçăo entre eles

Var
   N1, N2, N3: inteiro
   
Inicio
      escreval("---- MULTIPLICAÇĂO ENTRE 3 NÚMEROS ----")
      escreval
      escreva(" Digite o 1ş número: ")
      leia(N1)
      escreva(" Digite o 2ş número: ")
      leia(N2)
      escreva(" Digite o 3ş número: ")
      leia(N3)
      escreval
      escreval(" ",N1, " x ", N2, " x ", N3, " = ", N1 * N2 * N3)

Fimalgoritmo