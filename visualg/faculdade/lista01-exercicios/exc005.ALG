Algoritmo "EX05 L01"

// Exercício 05:
//    Calcule e apresente o perímetro de um círculo
//    Perímetro = 3,1416 * D, onde D = 2 * R

Var
   r: real

Inicio
      escreval(" ------- PERÍMETRO CÍRCULO -------")
      escreval
      escreva(" Qual o raio do círculo em metros? ")
      leia(r)
      escreval
      escreval(" PERÍMETRO = ", 3.1416*R*2:8:2, " m")

Fimalgoritmo