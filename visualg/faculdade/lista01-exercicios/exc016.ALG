Algoritmo "EX16 L01"

// Exercício 16
//    Leia 5 números fornecidos pelo usuário e calcule a soma total

Var
   N1, N2, N3, N4, N5: inteiro

Inicio
      escreval("--- SOMA DE 5 NÚMEROS ---")
      escreval
      escreva(" Digite o 1ş número: ")
      leia(N1)
      escreva(" Digite o 2ş número: ")
      leia(N2)
      escreva(" Digite o 3ş número: ")
      leia(N3)
      escreva(" Digite o 4ş número: ")
      leia(N4)
      escreva(" Digite o 5ş número: ")
      leia(N5)
      escreval
      escreval(" A soma dos números é ", N1 + N2 + N3 + N4 + N5)

Fimalgoritmo