Algoritmo "EX26 L01"

// ExercÌcio26
//    Solicite o nome e sal·rio de uma pessoa.
//    Apresente o sal·rio reduzido em 12,6%

Var
   nome: caractere
   s, r: real

Inicio
      escreval
      escreval(" --- REDU«√O DE SAL¡RIO EM 12,6% ---")
      escreval
      escreva(" Digite o nome: ")
      leia(nome)
      escreva(" Digite o sal·rio atual: R$")
      leia(s)
      r <- 0.126*s
      escreval
      escreval(" NOVO SAL¡RIO: R$", s - r:6:2)

Fimalgoritmo