Algoritmo "EX17 L01"

// Exercício 17:
//    Solicite o nome e a idade de 4 pessoas e calcule a média das idades

Var
   N1, N2, N3, N4: caractere
   I1, I2, I3, I4: inteiro
   M: real

Inicio
      escreval("         MÉDIA DE IDADES         ")
      escreval
      escreva(" Digite o nome da 1Ş pessoa: ")
      leia(N1)
      escreva(" Digite a idade da 1Ş pessoa: ")
      leia(I1)
      escreval("---------------------------------------")
      escreva(" Digite o nome da 2Ş pessoa: ")
      leia(N2)
      escreva(" Digite a idade da 2Ş pessoa: ")
      leia(I2)
      escreval("---------------------------------------")
      escreva(" Digite o nome da 3Ş pessoa: ")
      leia(N3)
      escreva(" Digite a idade da 3Ş pessoa: ")
      leia(I3)
      escreval("---------------------------------------")
      escreva(" Digite o nome da 4Ş pessoa: ")
      leia(N4)
      escreva(" Digite a idade da 4Ş pessoa: ")
      leia(I4)
      M <- (I1 + I2 + I3 + I4)/4
      limpatela
      
      escreval("------  MÉDIA DE IDADES  -------")
      escreval
      escreval(" Nome: ", N1)
      escreval(" Idade: ", I1)
      escreval
      escreval(" Nome: ", N2)
      escreval(" Idade: ", I2)
      escreval
      escreval(" Nome: ", N3)
      escreval(" Idade: ", I3)
      escreval
      escreval(" Nome: ", N4)
      escreval(" Idade: ", I4)
      escreval
      escreval("-------------------------------")
      escreval
      escreval(" MÉDIA = ", M:4:1)

Fimalgoritmo