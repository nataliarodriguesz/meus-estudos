Algoritmo "EX04 L01"

// Exercício 04
//    Calcule e apresente a área de um círculo
//    Área = 3,1416 * R² (R² significa R * R)

Var
   r: real

Inicio
      escreval(" ---------- ÁREA CÍRCULO ----------")
      escreval
      escreva(" Qual o raio do círculo em metros? ")
      leia(r)
      escreval
      escreval(" ÁREA = ", r*r*3.1416:8:2, "m")
      
Fimalgoritmo