Algoritmo "EX15 L02"

// Exercício 15:
//    Solicitar um número e informar se ele é PAR ou ÍMPAR.

Var
   n: inteiro

Inicio
   escreva("Digite um número: ")
   leia(n)
   escreval
   
   se (n%2 = 0) entao
      escreval ("O número ", n, " é PAR")
   senao
      escreval("O núemro ", n, " é ÍMPAR")
   fimse

Fimalgoritmo