Algoritmo "EX02 L02"

// Exercício 02:
//    Solicitar a pontuaçăo final de um jogador em uma partida.
//    Informar se ele atingiu o recorde da semana
//   (pontuaçăo mínima de 10.000 pontos).

Var
   P: inteiro

Inicio
   escreva("Digite sua pontuaçăo final: ")
   leia(P)
   escreval

   se (P >= 10000) entao
        escreval("Parabéns! Vocę atingiu o recorde da semana!")
   senao
        escreval("Vocę năo atingiu o recorde da semana ):")
   fimse

Fimalgoritmo