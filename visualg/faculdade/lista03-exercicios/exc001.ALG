Algoritmo "Ex01 L03"
// Exercício 01:
//    Solicite uma string (palavra ou frase) e exiba a quantidade
//    de caracteres que ela contém.

Var
   palavra: caractere

Inicio
      escreva("Digite uma palavra ou frase: ")
      leia(palavra)
      escreval
      escreval("A string digitada tem ", compr(palavra), " caracteres")

Fimalgoritmo