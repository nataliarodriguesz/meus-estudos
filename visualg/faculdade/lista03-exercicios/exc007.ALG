Algoritmo "Ex07 L03"

// Exercício 07:
// Solicite uma string e exiba cada caractere em uma linha separada.

Var
   string: caractere
   c: inteiro

Inicio
   escreva("Digite uma string: ")
   leia(string)
   escreval
   para c de 1 ate compr(string)faca
        escreval(" ", copia(string, c, 1))
   fimpara

Fimalgoritmo